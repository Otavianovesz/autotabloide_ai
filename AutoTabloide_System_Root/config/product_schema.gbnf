# GBNF Grammar for Product ETL Extraction
# Enforces strict JSON output from LLM
# Vol. IV, Cap. 1.4 - Deterministic Decoding

root ::= object

object ::= "{" ws (pair ("," ws pair)*)? "}" ws

pair ::= string ":" ws value

string ::= "\"" chars "\""

chars ::= char*

char ::= [a-zA-Z0-9_ 谩茅铆贸煤芒锚卯么没脿猫矛貌霉茫玫莽脕脡脥脫脷脗脢脦脭脹脌脠脤脪脵脙脮脟.,;:!?()/-]+

value ::= string | number | "null" | boolean | array

boolean ::= "true" | "false"

number ::= integer ("." [0-9]+)?

integer ::= "-"? [0-9]+

array ::= "[" ws (value ("," ws value)*)? "]" ws

ws ::= [ \t\n]*
